<div class="flex flex-col items-center justify-center min-h-full p-6 bg-dark-primary" style="background: linear-gradient(180deg, var(--color-dark-primary) 0%, var(--color-dark-secondary) 100%);">
    <div class="text-center max-w-sm">
        <h1 class="text-5xl font-bold text-neon-green mb-2 animate-slide-in-fade" style="font-family: 'Space Mono', monospace; text-shadow: 0 0 20px var(--color-neon-green);">SOC OPS</h1>
        <p class="text-3xl text-neon-cyan mb-8 animate-slide-in-fade" style="animation-delay: 100ms; font-family: 'Space Mono', monospace;">SOCIAL BINGO</p>

        <div class="bg-dark-secondary rounded-lg p-6 border border-neon-cyan mb-8 animate-slide-in-fade" style="animation-delay: 200ms; border-width: 2px;">
            <h2 class="font-semibold text-neon-green mb-3" style="font-size: 1.1rem; text-shadow: 0 0 10px var(--color-neon-green);">HOW TO PLAY</h2>
            <ul class="text-left text-light text-sm space-y-2">
                <li>• Find people who match the questions</li>
                <li>• Tap a square when you find a match</li>
                <li>• Get 5 in a row to win!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full bg-neon-green text-dark-primary font-bold py-4 px-8 rounded-lg text-lg transition-all duration-150 animate-slide-in-fade" style="animation-delay: 300ms; box-shadow: 0 0 20px rgba(0, 255, 136, 0.4);">
            START GAME
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
