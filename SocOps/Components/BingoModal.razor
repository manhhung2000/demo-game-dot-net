<div class="fixed inset-0 flex items-center justify-center p-4 z-50" style="background: radial-gradient(circle, rgba(255, 0, 255, 0.1) 0%, rgba(0, 212, 255, 0.05) 50%, transparent 100%);">
    <div class="bg-dark-secondary rounded-xl p-6 max-w-xs w-full text-center animate-modal-entrance" style="border: 2px solid var(--color-neon-cyan); box-shadow: 0 0 40px rgba(0, 212, 255, 0.5), inset 0 0 30px rgba(0, 212, 255, 0.1);">
        <div class="text-5xl mb-4 animate-pulse-neon">🎉</div>
        <h2 class="text-4xl font-bold text-neon-green mb-2" style="font-family: 'Space Mono', monospace; text-shadow: 0 0 20px var(--color-neon-green);">BINGO!</h2>
        <p class="text-neon-cyan mb-6" style="font-size: 1.1rem;">YOU COMPLETED A LINE!</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-neon-green text-dark-primary font-bold py-3 px-6 rounded-lg transition-all duration-150" style="box-shadow: 0 0 20px rgba(0, 255, 136, 0.4);">
            KEEP PLAYING
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
