@using SocOps.Models

<div class="flex flex-col min-h-full bg-dark-primary">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 bg-dark-secondary border-b border-dark-tertiary" style="border-bottom-width: 2px; border-color: var(--color-neon-green);">
        <button
            @onclick="OnReset"
            class="text-neon-green text-sm px-3 py-1.5 rounded transition-all duration-150" style="text-shadow: 0 0 8px var(--color-neon-green);">
            ← Back
        </button>
        <h1 class="font-bold text-neon-green" style="font-family: 'Space Mono', monospace; font-size: 1.25rem; text-shadow: 0 0 20px var(--color-neon-green);">SOC OPS</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-light text-sm py-2 px-4">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-dark-secondary text-center py-2 font-semibold text-sm animate-pulse-neon" style="background-color: rgba(255, 0, 255, 0.1); border-top: 2px solid var(--color-neon-pink); border-bottom: 2px solid var(--color-neon-pink); color: var(--color-neon-pink); text-shadow: 0 0 10px var(--color-neon-pink);">
            🎉 BINGO! YOU GOT A LINE!
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
