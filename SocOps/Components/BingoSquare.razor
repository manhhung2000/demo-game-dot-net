@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-neon-green text-xs" style="text-shadow: 0 0 8px var(--color-neon-green); font-size: 1.2rem;">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-1 text-center border rounded transition-all duration-150 select-none min-h-[60px] text-xs leading-tight";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-dark-secondary border-neon-pink text-neon-pink"
                : "bg-dark-secondary border-neon-green text-neon-green"
            : "bg-dark-secondary border-dark-tertiary text-light hover:scale-105 hover:border-neon-green";

        var stateStyles = Square.IsMarked
            ? IsWinning
                ? "border-width: 2px; box-shadow: 0 0 20px rgba(255, 0, 255, 0.4), inset 0 0 10px rgba(255, 0, 255, 0.1);"
                : "border-width: 2px; box-shadow: 0 0 20px rgba(0, 255, 136, 0.4), inset 0 0 10px rgba(0, 255, 136, 0.1);"
            : "border-width: 1px;";

        var freeSpaceClasses = Square.IsFreeSpace ? "font-bold text-sm bg-dark-tertiary border-neon-cyan" : "";
        var freeSpaceStyle = Square.IsFreeSpace ? "border-width: 2px; box-shadow: 0 0 15px rgba(0, 212, 255, 0.3), inset 0 0 10px rgba(0, 212, 255, 0.1);" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
